<% const safeCurrentUser=typeof currentUser !=='undefined' ? currentUser : null; const safePageTitle=typeof pageTitle
  !=='undefined' && pageTitle ? pageTitle : 'Dashboard' ; const userInitial=safeCurrentUser && safeCurrentUser.username
  ? safeCurrentUser.username.slice(0, 1).toUpperCase() : 'U' ; %>

  <nav
    class="fixed top-0 right-0 z-40 w-full border-b border-slate-200 bg-white shadow-sm sm:w-[calc(100%-16rem)] dark:border-slate-800 dark:bg-slate-900">
    <div class="px-3 py-2.5 lg:px-5 lg:pl-3">
      <div class="flex items-center justify-between">
        <div class="flex min-w-0 items-center justify-start gap-3 rtl:justify-end">
          <button id="sidebar-toggle" data-drawer-target="app-sidebar" data-drawer-toggle="app-sidebar"
            aria-controls="app-sidebar" type="button"
            class="inline-flex items-center rounded-xl border border-slate-200 bg-transparent p-2 text-sm font-medium leading-5 text-slate-600 hover:bg-slate-100 focus:outline-none focus:ring-4 focus:ring-slate-200 sm:hidden dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 dark:focus:ring-slate-800">
            <span class="sr-only">Abrir menú lateral</span>
            <i class="fa-solid fa-bars h-5 w-5"></i>
          </button>

          <div class="min-w-0">
            <p
              class="hidden text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 md:block dark:text-slate-400">
              Plataforma Operacional
            </p>
            <h1 class="truncate text-sm font-semibold text-[#0D0D0D] sm:text-base dark:text-white">
              <%= safePageTitle %>
            </h1>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <div
            class="hidden items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700 md:inline-flex dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-300">
            <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
            <span id="sync-status-label">Sincronizado</span>
          </div>

          <button id="theme-toggle" type="button"
            class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 transition hover:bg-slate-100 focus:outline-none focus:ring-4 focus:ring-slate-200 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:focus:ring-slate-800"
            aria-label="Cambiar tema">
            <i id="theme-toggle-dark-icon" class="fa-solid fa-moon hidden text-sm"></i>
            <i id="theme-toggle-light-icon" class="fa-solid fa-sun hidden text-sm"></i>
          </button>

          <div class="relative ms-1">
            <button type="button"
              class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-2 py-1.5 text-sm shadow-sm transition hover:bg-slate-50 focus:outline-none focus:ring-4 focus:ring-slate-200 dark:border-slate-700 dark:bg-slate-900 dark:hover:bg-slate-800 dark:focus:ring-slate-800"
              aria-expanded="false" data-dropdown-toggle="dropdown-user">
              <span class="sr-only">Abrir menú de usuario</span>

              <div class="hidden text-right sm:block">
                <p class="max-w-[120px] truncate text-sm font-semibold text-[#0D0D0D] dark:text-white">
                  <%= safeCurrentUser ? safeCurrentUser.username : 'Usuario' %>
                </p>
                <p class="text-[11px] text-slate-500 dark:text-slate-400">
                  <%= safeCurrentUser ? safeCurrentUser.role : 'Sin rol' %>
                </p>
              </div>

              <div
                class="flex h-8 w-8 items-center justify-center rounded-full bg-[#033F73] text-sm font-bold text-white dark:bg-[#023059]">
                <%= userInitial %>
              </div>
            </button>

            <div id="dropdown-user"
              class="z-50 hidden w-60 divide-y divide-slate-100 rounded-2xl border border-slate-200 bg-white shadow-xl dark:divide-slate-700 dark:border-slate-700 dark:bg-slate-900">
              <div class="px-4 py-3" role="none">
                <p class="text-sm font-semibold text-[#0D0D0D] dark:text-white" role="none">
                  <%= safeCurrentUser ? safeCurrentUser.username : 'Usuario' %>
                </p>
                <p class="truncate text-sm text-slate-500 dark:text-slate-400" role="none">
                  <%= safeCurrentUser ? safeCurrentUser.role : 'Sin rol' %>
                </p>
                <% if (safeCurrentUser && safeCurrentUser.department) { %>
                  <p class="mt-1 truncate text-xs text-slate-400 dark:text-slate-500" role="none">
                    <%= safeCurrentUser.department %>
                  </p>
                  <% } %>
              </div>

              <ul class="space-y-1 p-2 text-sm font-medium text-slate-700 dark:text-slate-200" role="none">
                <li>
                  <a href="/dashboard"
                    class="flex items-center gap-2 rounded-xl px-3 py-2 transition hover:bg-slate-100 dark:hover:bg-slate-800"
                    role="menuitem">
                    <i class="fa-solid fa-house w-4 text-center"></i>
                    <span>Dashboard</span>
                  </a>
                </li>

                <% if (safeCurrentUser && safeCurrentUser.role==='admin' ) { %>
                  <li>
                    <a href="/usuarios/crear"
                      class="flex items-center gap-2 rounded-xl px-3 py-2 transition hover:bg-slate-100 dark:hover:bg-slate-800"
                      role="menuitem">
                      <i class="fa-solid fa-users w-4 text-center"></i>
                      <span>Usuarios</span>
                    </a>
                  </li>
                  <% } %>

                    <li>
                      <form method="post" action="/logout">
                        <button type="submit"
                          class="flex w-full items-center gap-2 rounded-xl px-3 py-2 text-left transition hover:bg-slate-100 dark:hover:bg-slate-800"
                          role="menuitem">
                          <i class="fa-solid fa-right-from-bracket w-4 text-center"></i>
                          <span>Cerrar sesión</span>
                        </button>
                      </form>
                    </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>