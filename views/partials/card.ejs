<div
  class="min-w-0 flex-[1_1_calc(50%-0.5rem)] rounded-lg border border-gray-200 bg-white px-3 py-2 shadow-sm dark:border-gray-700 dark:bg-gray-800 sm:flex-[1_1_130px] lg:flex-1">
  <p class="truncate text-[11px] font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
    <%= title %>
  </p>

  <p class="mt-1 text-xl font-bold leading-tight text-gray-900 dark:text-white">
    <%= value %>
  </p>

  <% if (subtitle) { %>
    <p class="truncate text-[11px] text-gray-500 dark:text-gray-400">
      <%= subtitle %>
    </p>
    <% } %>
</div>