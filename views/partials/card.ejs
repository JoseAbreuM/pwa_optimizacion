<article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
  <% if (typeof title !== 'undefined' && title) { %>
    <h3 class="text-sm font-semibold text-slate-500"><%= title %></h3>
  <% } %>
  <div class="mt-2">
    <%- body %>
  </div>
</article>
