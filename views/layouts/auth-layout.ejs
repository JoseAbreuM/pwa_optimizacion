<!DOCTYPE html>
<html lang="es" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#033F73" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/assets/icons/icono.png" />
  <script>
    (function () {
      const storedTheme = localStorage.getItem('color-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const shouldUseDark = storedTheme === 'dark' || (!storedTheme && systemPrefersDark);
      document.documentElement.classList.toggle('dark', shouldUseDark);
    })();
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/tailwind.css" />
  <link rel="stylesheet" href="/css/app.css" />
  <title><%= title %> | Cavallino</title>
</head>

<body class="min-h-screen bg-brand-bg text-brand-dark dark:bg-slate-950 dark:text-white">
  <%- body %>

  <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
  <script src="/js/sw-register.js" defer></script>
</body>

</html>
