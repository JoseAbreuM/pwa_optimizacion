<!DOCTYPE html>
<html lang="es" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#033F73" />

  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/assets/icons/icono.png" />

  <!-- Tema inicial antes de pintar la pantalla -->
  <script>
    (function () {
      const storedTheme = localStorage.getItem('color-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const shouldUseDark = storedTheme === 'dark' || (!storedTheme && systemPrefersDark);

      document.documentElement.classList.toggle('dark', shouldUseDark);
    })();
  </script>

  <!-- Iconos -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

  <!-- DataTables CSS -->
  <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.dataTables.min.css" />
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.2.2/css/buttons.dataTables.min.css" />
  <link rel="stylesheet" href="https://cdn.datatables.net/colreorder/2.0.4/css/colReorder.dataTables.min.css" />

  <!-- Estilos propios -->
  <link rel="stylesheet" href="/css/tailwind.css" />
  <link rel="stylesheet" href="/css/app.css" />

  <title>
    <%= typeof title !=='undefined' ? title : 'Dashboard' %> | Cavallino
  </title>
</head>

<body
  class="min-h-screen overflow-x-hidden bg-[#F2F2F2] text-[#0D0D0D] antialiased dark:bg-[#0f172a] dark:text-slate-100">

  <%- include('../partials/sidebar', { currentSection: typeof currentSection !=='undefined' ? currentSection : '' ,
    currentUser: typeof currentUser !=='undefined' ? currentUser : null }) %>

    <%- include('../partials/topbar', { currentUser: typeof currentUser !=='undefined' ? currentUser : null, pageTitle:
      typeof title !=='undefined' ? title : 'Dashboard' }) %>

      <!--
    Importante:
    pt-20 compensa el topbar fijo.
    lg:pl-64 compensa el sidebar fijo en desktop.
  -->
      <main id="app-main" class="min-h-screen min-w-0 overflow-x-hidden pt-20 lg:pl-64">
        <div class="w-full min-w-0 px-3 pb-6 sm:px-4 lg:px-6">
          <div class="mx-auto w-full max-w-screen-2xl min-w-0 space-y-5">
            <%- body %>
          </div>
        </div>
      </main>

      <!-- Librerías base -->
      <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

      <!-- ApexCharts -->
      <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

      <!-- Flowbite -->
      <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>

      <!-- DataTables -->
      <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>

      <!-- DataTables Buttons -->
      <script src="https://cdn.datatables.net/buttons/3.2.2/js/dataTables.buttons.min.js"></script>
      <script src="https://cdn.datatables.net/buttons/3.2.2/js/buttons.html5.min.js"></script>

      <!-- DataTables ColReorder -->
      <script src="https://cdn.datatables.net/colreorder/2.0.4/js/dataTables.colReorder.min.js"></script>

      <!-- Dependencia para exportar Excel -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

      <!-- Scripts offline/core -->
      <script src="/js/offline/db.js"></script>
      <script src="/js/offline/sync.js"></script>
      <script src="/js/offline/status.js"></script>
      <script src="/js/core/ui.js"></script>
      <script src="/js/core/app.js"></script>
      <script src="/js/sw-register.js"></script>
      <script src="/js/app-theme.js"></script>

      <!-- Script específico de cada página -->
      <% if (typeof pageScript !=='undefined' && pageScript) { %>
        <script src="<%= pageScript %>"></script>
        <% } %>

</body>

</html>