<!DOCTYPE html>
<html lang="es" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#033F73" />

  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/assets/icons/icono.png" />

  <script>
    (function () {
      const storedTheme = localStorage.getItem('color-theme');
      const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const shouldUseDark = storedTheme === 'dark' || (!storedTheme && systemPrefersDark);
      document.documentElement.classList.toggle('dark', shouldUseDark);
    })();
  </script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

  <link rel="stylesheet" href="/css/tailwind.css" />
  <link rel="stylesheet" href="/css/app.css" />

  <script src="https://cdn.jsdelivr.net/npm/apexcharts" defer></script>

  <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js" defer></script>

  <title>
    <%= title %> | Cavallino
  </title>
</head>

<body
  class="min-h-screen overflow-x-hidden bg-[#F2F2F2] text-[#0D0D0D] antialiased dark:bg-[#0f172a] dark:text-slate-100">

  <%- include('../partials/sidebar', { currentSection: typeof currentSection !=='undefined' ? currentSection : '' ,
    currentUser: typeof currentUser !=='undefined' ? currentUser : null }) %>

    <%- include('../partials/topbar', { currentUser: typeof currentUser !=='undefined' ? currentUser : null, pageTitle:
      typeof title !=='undefined' ? title : 'Dashboard' }) %>

      <main id="app-main" class="min-h-screen min-w-0 overflow-x-hidden">
        <div class="w-full min-w-0 px-3 pb-6 sm:px-4 lg:px-6">
          <div class="mx-auto w-full max-w-screen-2xl min-w-0 space-y-5">
            <%- body %>
          </div>
        </div>
      </main>

      <script src="/js/offline/db.js" defer></script>
      <script src="/js/offline/store.js" defer></script>
      <script src="/js/offline/sync.js" defer></script>
      <script src="/js/core/ui.js" defer></script>
      <script src="/js/core/app.js" defer></script>
      <script src="/js/sw-register.js" defer></script>

      <% if (typeof pageScript !=='undefined' && pageScript) { %>
        <script src="<%= pageScript %>" defer></script>
        <% } %>

</body>

</html>