              class="sticky top-0 z-10 bg-blue-50 text-xs uppercase text-blue-900 dark:bg-blue-950 dark:text-blue-200">
              <tr>
                <th class="px-4 py-3">Fecha</th>
                <th class="px-4 py-3">Torque</th>
                <th class="px-4 py-3">AMP</th>
                <th class="px-4 py-3">Freq</th>
                <th class="px-4 py-3">Volts</th>
                <th class="px-4 py-3">HP</th>
                <th class="px-4 py-3">VO</th>
                <th class="px-4 py-3">Vel. actual</th>
                <th class="px-4 py-3">P. casing</th>
                <th class="px-4 py-3">P. tubing</th>
                <th class="px-4 py-3">Observación</th>
                <th class="px-4 py-3">Recomendación</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <% if (parametros && parametros.length) { %>
                <% parametros.forEach(function(row, index) { %>
                  <tr
                    class="<%= index % 2 === 0 ? 'bg-white dark:bg-slate-900' : 'bg-slate-50/80 dark:bg-slate-800/50' %> hover:bg-blue-50 dark:hover:bg-blue-950/30">
                    <td class="whitespace-nowrap px-4 py-3 font-semibold text-slate-900 dark:text-white">
                      <%= formatDate(row.fecha) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.torque, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.amp, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.freq, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.volts, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.hp, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.vel_operacional, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.vel_actual, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.presion_casing, 2) %>
                    </td>
                    <td class="px-4 py-3">
                      <%= formatNumber(row.presion_tubing, 2) %>
                    </td>
                    <td class="max-w-[320px] truncate px-4 py-3" title="<%= fallback(row.observacion) %>">
                      <%= fallback(row.observacion) %>
                    </td>
                    <td class="max-w-[360px] truncate px-4 py-3"
                      title="<%= fallback(row.recomendaciones_completas || row.recomendacion || row.recomendaciones) %>">
                      <%= fallback(row.recomendaciones_completas || row.recomendacion || row.recomendaciones) %>
                    </td>
                  </tr>
                  <% }); %>
                    <% } else { %>
                      <tr>
                        <td colspan="12" class="px-4 py-6 text-center text-slate-500 dark:text-slate-400">
                          No hay parámetros registrados.
                        </td>
                      </tr>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

