          RPM
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="nivel-chart-field" value="torque">
          Torque
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="nivel-chart-field" value="amp">
