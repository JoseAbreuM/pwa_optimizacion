<% const parametros=typeof historialParametros !=='undefined' ? historialParametros : (timeline?.parametros || []);
  const niveles=typeof historialNiveles !=='undefined' ? historialNiveles : (timeline?.niveles || []); const
  comparativo=typeof comparativoParametrosNiveles !=='undefined' ? comparativoParametrosNiveles : (timeline?.comparativo
  || []); const ultimoComparativo=comparativo && comparativo.length ? comparativo[0] : null; %>

  <div class="space-y-5">

    <!-- =========================================================
       RESUMEN PARAMETROS
       ========================================================= -->
    <section
      class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <div
        class="border-b border-slate-100 bg-gradient-to-r from-blue-50 via-white to-slate-50 p-4 dark:border-slate-800 dark:from-blue-950/30 dark:via-slate-900 dark:to-slate-900">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <div class="flex items-center gap-2">
              <span
                class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">
                <i class="fa-solid fa-sliders"></i>
              </span>

              <div>
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
                  Últimos parámetros
                </h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  Último registro operativo tomado desde la carga de parámetros.
                </p>
              </div>
            </div>
          </div>

          <button type="button" data-pozo-open-modal="modal-historial-parametros"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-blue-200 bg-white px-3 py-2 text-sm font-medium text-blue-700 shadow-sm hover:bg-blue-50 dark:border-blue-800 dark:bg-slate-900 dark:text-blue-300 dark:hover:bg-blue-950/40">
            <i class="fa-solid fa-table-list"></i>
            Ver histórico
          </button>
        </div>
      </div>

      <div class="p-4">
        <% if (ultimoParametro) { %>
          <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-4 xl:grid-cols-8">

            <div
              class="rounded-2xl border border-slate-100 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/70">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Fecha</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatDate(ultimoParametro.fecha) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-orange-100 bg-orange-50 px-3 py-3 dark:border-orange-900/40 dark:bg-orange-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-orange-700 dark:text-orange-300">Torque
              </p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.torque, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-amber-100 bg-amber-50 px-3 py-3 dark:border-amber-900/40 dark:bg-amber-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-300">AMP</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.amp, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-cyan-100 bg-cyan-50 px-3 py-3 dark:border-cyan-900/40 dark:bg-cyan-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-cyan-700 dark:text-cyan-300">Freq</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.freq, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-purple-100 bg-purple-50 px-3 py-3 dark:border-purple-900/40 dark:bg-purple-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-purple-700 dark:text-purple-300">Volts
              </p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.volts, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-emerald-100 bg-emerald-50 px-3 py-3 dark:border-emerald-900/40 dark:bg-emerald-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">HP</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.hp, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-indigo-100 bg-indigo-50 px-3 py-3 dark:border-indigo-900/40 dark:bg-indigo-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-indigo-700 dark:text-indigo-300">VO</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.vel_operacional, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-sky-100 bg-sky-50 px-3 py-3 dark:border-sky-900/40 dark:bg-sky-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-sky-700 dark:text-sky-300">Vel. actual
              </p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.vel_actual, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-rose-100 bg-rose-50 px-3 py-3 dark:border-rose-900/40 dark:bg-rose-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-rose-700 dark:text-rose-300">P. casing
              </p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.presion_casing, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-teal-100 bg-teal-50 px-3 py-3 dark:border-teal-900/40 dark:bg-teal-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">P. tubing
              </p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoParametro.presion_tubing, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-slate-100 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/70 sm:col-span-2 md:col-span-2 xl:col-span-6">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                Observación / recomendación</p>
              <p class="mt-1 line-clamp-2 text-sm font-medium text-slate-800 dark:text-slate-200"
                title="<%= fallback(ultimoParametro.recomendaciones_completas || ultimoParametro.observacion) %>">
                <%= fallback(ultimoParametro.recomendaciones_completas || ultimoParametro.observacion) %>
              </p>
            </div>

          </div>
          <% } else { %>
            <div class="rounded-xl bg-yellow-50 p-4 text-sm text-yellow-700 dark:bg-yellow-900/20 dark:text-yellow-300">
              No hay parámetros registrados para este pozo.
            </div>
            <% } %>
      </div>
    </section>

    <!-- =========================================================
       GRAFICA PARAMETROS
       ========================================================= -->
    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <div class="mb-4 flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
            Gráfica inteligente de parámetros
          </h2>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Selecciona uno o varios parámetros y un periodo para visualizar sus tendencias.
          </p>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
          <select id="parametros-periodo"
            class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200">
            <option value="7">1 semana</option>
            <option value="30" selected>1 mes</option>
            <option value="90">3 meses</option>
            <option value="180">6 meses</option>
            <option value="all">Todo</option>
          </select>

          <button type="button" data-export-chart="chart-parametros-pozo"
            data-export-name="parametros-<%= pozo.codigo %>"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700">
            <i class="fa-solid fa-download"></i>
            Exportar PNG
          </button>
        </div>
      </div>

      <div class="mb-4 flex flex-wrap gap-2 text-sm">
        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="torque" checked>
          Torque
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="amp">
          AMP
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="freq">
          Freq
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="volts">
          Volts
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="hp">
          HP
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="vel_operacional">
          VO
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="vel_actual">
          Vel. actual
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="presion_casing">
          P. casing
        </label>

        <label class="inline-flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2 dark:bg-slate-800">
          <input type="checkbox" name="parametro-chart-field" value="presion_tubing">
          P. tubing
        </label>
      </div>

      <script type="application/json" id="parametros-data-json"><%- JSON.stringify(parametros || []) %></script>

      <div id="chart-parametros-pozo"
        class="min-h-[320px] rounded-xl border border-dashed border-slate-300 bg-white p-2 dark:border-slate-600 dark:bg-slate-900">
        <% if (!parametros || !parametros.length) { %>
          <div class="flex min-h-[300px] items-center justify-center">
            <p class="text-sm text-slate-500 dark:text-slate-400">
              Gráfica de parámetros pendiente.
            </p>
          </div>
          <% } %>
      </div>
    </section>

    <!-- =========================================================
       RESUMEN NIVELES
       ========================================================= -->
    <section
      class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <div
        class="border-b border-slate-100 bg-gradient-to-r from-emerald-50 via-white to-slate-50 p-4 dark:border-slate-800 dark:from-emerald-950/30 dark:via-slate-900 dark:to-slate-900">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div class="flex items-center gap-2">
            <span
              class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">
              <i class="fa-solid fa-water"></i>
            </span>

            <div>
              <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
                Última toma de nivel
              </h2>
              <p class="text-sm text-slate-500 dark:text-slate-400">
                Último registro cargado desde la base de niveles.
              </p>
            </div>
          </div>

          <button type="button" data-pozo-open-modal="modal-historial-niveles"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-200 bg-white px-3 py-2 text-sm font-medium text-emerald-700 shadow-sm hover:bg-emerald-50 dark:border-emerald-800 dark:bg-slate-900 dark:text-emerald-300 dark:hover:bg-emerald-950/40">
            <i class="fa-solid fa-table-list"></i>
            Ver histórico
          </button>
        </div>
      </div>

      <div class="p-4">
        <% if (ultimoNivel) { %>
          <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-4 xl:grid-cols-10">

            <div
              class="rounded-2xl border border-slate-100 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/70">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Fecha</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatDate(ultimoNivel.fecha) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-blue-100 bg-blue-50 px-3 py-3 dark:border-blue-900/40 dark:bg-blue-950/20">
              <p class="text-[10px] font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-300">NF pies</p>
              <p class="mt-1 text-sm font-bold text-slate-900 dark:text-white">
                <%= formatNumber(ultimoNivel.nf_pies, 2) %>
              </p>
            </div>

            <div
              class="rounded-2xl border border-emerald-100 bg-emerald-50 px-3 py-3 dark:border-emerald-900/40 dark:bg-emerald-950/20">
