<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
  <h2 class="text-lg font-semibold">Muestras</h2>
  <div class="mt-4 space-y-2 text-sm">
    <% if (!timeline.muestras.length) { %><p class="text-slate-500">Sin registros.</p><% } %>
    <% timeline.muestras.forEach(item => { %>
      <div class="rounded-xl bg-slate-50 p-3 dark:bg-slate-800">
        <div class="font-semibold"><%= new Date(item.fecha).toLocaleDateString('es-VE') %></div>
        <div>AYS: <%= item.ays || '—' %> · API: <%= item.api || '—' %></div>
      </div>
    <% }) %>
  </div>
</article>
