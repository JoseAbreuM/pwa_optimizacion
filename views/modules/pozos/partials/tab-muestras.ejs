<% var muestras=[]; if (typeof ultimasMuestras !=='undefined' && Array.isArray(ultimasMuestras)) {
  muestras=ultimasMuestras; } else if (typeof timeline !=='undefined' && timeline && Array.isArray(timeline.muestras)) {
  muestras=timeline.muestras; } %>

  <div id="tab-muestras-pozo"
    class="space-y-4 rounded-2xl bg-slate-50 p-3 text-slate-900 dark:bg-slate-950 dark:text-slate-100 sm:p-4">

    <!-- =========================================================
   TABLA MUESTRAS
   ========================================================= -->
    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
            Muestras
          </h2>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            Histórico de muestras registradas para este pozo. Marca como representativas las muestras que quieras ver en
            la gráfica.
          </p>
        </div>

        <button type="button"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-[#033F73] px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-[#022f56]">
          <i class="fa-solid fa-plus"></i>
          Nueva muestra
        </button>
      </div>

      <script type="application/json" id="muestras-data-json"><%- JSON.stringify(muestras || []) %></script>

      <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-900">
        <table id="tabla-muestras-pozo"
          class="w-full min-w-[900px] text-left text-sm text-slate-600 dark:text-slate-300">
          <thead class="bg-slate-50 text-xs uppercase text-slate-700 dark:bg-slate-800 dark:text-slate-300">
            <tr>
              <th class="px-4 py-3">Fecha</th>
              <th class="px-4 py-3">% AyS</th>
              <th class="px-4 py-3">API</th>
              <th class="px-4 py-3">Próx. muestra</th>
              <th class="px-4 py-3">Acción</th>
              <th class="px-4 py-3 text-center">Representativa</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            <% if (muestras && muestras.length) { %>
              <% muestras.forEach(function(muestra, index) { var fechaRaw=muestra.fecha || '' ; var fechaIso=fechaRaw ?
                String(fechaRaw).slice(0, 10) : '' ; var proxRaw=muestra.prox_muestra || '' ; var proxIso=proxRaw ?
                String(proxRaw).slice(0, 10) : '' ; var isRepresentativa=muestra.representativa===true ||
                muestra.representativa===1 || muestra.representativa==='1' || muestra.representativa==='true' ; %>
                <tr
                  class="<%= index % 2 === 0 ? 'bg-white dark:bg-slate-900' : 'bg-slate-50/70 dark:bg-slate-800/40' %> hover:bg-slate-50 dark:hover:bg-slate-800/70">
                  <td class="whitespace-nowrap px-4 py-3 font-semibold text-slate-900 dark:text-white"
                    data-order="<%= fechaIso %>">
                    <%= fallback(formatDate(muestra.fecha)) %>
                  </td>

                  <td class="whitespace-nowrap px-4 py-3 font-medium text-slate-700 dark:text-slate-200"
                    data-order="<%= muestra.ays != null ? muestra.ays : '' %>">
                    <%= fallback(formatNumber(muestra.ays, 2)) %>
                  </td>

                  <td class="whitespace-nowrap px-4 py-3" data-order="<%= muestra.api != null ? muestra.api : '' %>">
                    <%= fallback(formatNumber(muestra.api, 2)) %>
                  </td>

                  <td class="whitespace-nowrap px-4 py-3" data-order="<%= proxIso %>">
                    <%= fallback(formatDate(muestra.prox_muestra)) %>
                  </td>

                  <td class="whitespace-nowrap px-4 py-3">
                    <button type="button"
                      class="inline-flex items-center gap-1.5 font-medium text-[#033F73] hover:underline dark:text-sky-300">
                      <i class="fa-solid fa-pen-to-square text-xs"></i>
                      Editar
                    </button>
                  </td>

                  <td class="whitespace-nowrap px-4 py-3 text-center" data-order="<%= isRepresentativa ? 1 : 0 %>">
                    <label class="inline-flex cursor-pointer items-center justify-center">
                      <input type="checkbox" class="peer sr-only" data-muestra-representativa
                        data-muestra-id="<%= muestra.id %>" data-pozo-id="<%= pozo.id %>" data-fecha="<%= fechaIso %>"
                        data-ays="<%= muestra.ays != null ? muestra.ays : '' %>" <%=isRepresentativa ? 'checked' : '' %>
                      >

                      <span
                        class="relative h-6 w-11 rounded-full bg-slate-300 transition after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow after:transition peer-checked:bg-emerald-600 peer-checked:after:translate-x-5 dark:bg-slate-700">
                      </span>

                      <span
                        class="ml-2 text-xs font-semibold text-slate-500 peer-checked:text-emerald-700 dark:text-slate-400 dark:peer-checked:text-emerald-300">
                        <%= isRepresentativa ? 'Sí' : 'No' %>
                      </span>
                    </label>
                  </td>
                </tr>
                <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="6" class="px-4 py-6 text-center text-slate-500 dark:text-slate-400">
                        No hay muestras registradas.
                      </td>
                    </tr>
                    <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- =========================================================
   GRAFICA MUESTRAS
   ========================================================= -->
    <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
            Gráfica de muestras representativas
          </h2>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
            Comportamiento de agua y sedimentos (% AyS) en el tiempo.
          </p>
        </div>

        <button type="button" data-export-chart="chart-muestras-pozo" data-export-name="muestras-<%= pozo.codigo %>"
          data-export-pozo="<%= pozo.codigo %>" data-export-kind="muestras"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-amber-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-amber-700">
          <i class="fa-solid fa-download"></i>
          Exportar PNG
        </button>
      </div>

      <div
        class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-2 dark:border-slate-600 dark:bg-slate-950/70">
        <div id="chart-muestras-pozo"
          class="min-h-[320px] rounded-lg bg-white text-slate-700 dark:bg-slate-950 dark:text-slate-200">
          <% if (!muestras || !muestras.length) { %>
            <div class="flex min-h-[300px] items-center justify-center">
              <p class="text-sm text-slate-500 dark:text-slate-400">
                No hay muestras disponibles para graficar.
              </p>
            </div>
            <% } else { %>
              <div class="flex min-h-[300px] items-center justify-center">
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  Marca una o más muestras como representativas para graficar % AyS.
                </p>
              </div>
              <% } %>
        </div>
      </div>
    </section>

  </div>

  <style>
    html.dark #tab-muestras-pozo {
      background-color: rgb(2 6 23);
      color: rgb(226 232 240);
    }

    html.dark #tab-muestras-pozo section {
      background-color: rgb(15 23 42);
      border-color: rgb(51 65 85);
    }

    html.dark #tab-muestras-pozo .bg-white {
      background-color: rgb(15 23 42);
    }

    html.dark #tab-muestras-pozo .bg-slate-50 {
      background-color: rgb(15 23 42);
    }

    html.dark #tab-muestras-pozo table,
    html.dark #tab-muestras-pozo tbody,
    html.dark #tab-muestras-pozo tr {
      background-color: transparent;
    }

    html.dark #chart-muestras-pozo {
      background-color: rgb(2 6 23);
      color: rgb(226 232 240);
    }

    html.dark #chart-muestras-pozo .apexcharts-canvas,
    html.dark #chart-muestras-pozo svg {
      background-color: transparent !important;
    }

    html.dark #chart-muestras-pozo .apexcharts-title-text,
    html.dark #chart-muestras-pozo .apexcharts-text,
    html.dark #chart-muestras-pozo .apexcharts-xaxis-label,
    html.dark #chart-muestras-pozo .apexcharts-yaxis-label,
    html.dark #chart-muestras-pozo .apexcharts-legend-text {
      fill: rgb(203 213 225) !important;
      color: rgb(203 213 225) !important;
    }

    html.dark #chart-muestras-pozo .apexcharts-gridline {
      stroke: rgb(51 65 85) !important;
    }

    html.dark #chart-muestras-pozo .apexcharts-tooltip,
    html.dark #chart-muestras-pozo .apexcharts-tooltip-title {
      background-color: rgb(15 23 42) !important;
      border-color: rgb(51 65 85) !important;
      color: rgb(226 232 240) !important;
    }

    html.dark #chart-muestras-pozo .apexcharts-tooltip-text,
    html.dark #chart-muestras-pozo .apexcharts-tooltip-text-y-label,
    html.dark #chart-muestras-pozo .apexcharts-tooltip-text-y-value {
      color: rgb(226 232 240) !important;
    }

    html.dark #tab-muestras-pozo input,
    html.dark #tab-muestras-pozo select {
      background-color: rgb(15 23 42);
      color: rgb(226 232 240);
      border-color: rgb(71 85 105);
    }
  </style>