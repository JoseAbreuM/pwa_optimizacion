<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
  <h2 class="text-lg font-semibold">General</h2>
  <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
    <div>
      <dt class="text-slate-500">Código</dt>
      <dd class="font-medium">
        <%= pozo.codigo %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Estado</dt>
      <dd class="font-medium">
        <%= pozo.estado %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Área</dt>
      <dd class="font-medium">
        <%= pozo.area %>
      </dd>
    </div>
    <div>
      <dt class="text-slate-500">Yacimiento</dt>
      <dd class="font-medium">
        <%= pozo.yacimiento || '—' %>
      </dd>
    </div>
  </dl>
</article>