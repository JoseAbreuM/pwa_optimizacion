<div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
  <div>
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Personal</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Personal fijo de los departamentos.
    </p>
  </div>

  <% if (currentUser?.canManagePersonal) { %>
    <a href="/usuarios/personal/crear"
      class="inline-flex items-center justify-center rounded-lg bg-[#033F73] px-4 py-2 text-sm font-semibold text-white hover:bg-[#023059]">
      <i class="fa-solid fa-plus mr-2"></i>
      Nuevo personal
    </a>
    <% } %>
</div>

<div class="min-w-0 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
  <div class="w-full overflow-x-auto">
    <table id="tabla-personal" class="w-full text-left text-sm">
      <thead class="bg-gray-50 text-xs uppercase text-gray-500 dark:bg-gray-700 dark:text-gray-300">
        <tr>
          <th class="px-3 py-2">Nombre</th>
          <th class="px-3 py-2">Cédula</th>
          <th class="px-3 py-2">Departamento</th>
          <th class="px-3 py-2">Estado</th>
          <th class="px-3 py-2">Acciones</th>
        </tr>
      </thead>

      <tbody>
        <% if (personal && personal.length) { %>
          <% personal.forEach((p)=> { %>
            <tr class="border-t hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
              <td class="whitespace-nowrap px-3 py-2 font-semibold text-gray-900 dark:text-white">
                <%= p.nombre_completo || '-' %>
              </td>

              <td class="px-3 py-2 text-gray-600 dark:text-gray-300">
                <%= p.cedula || '-' %>
              </td>

              <td class="px-3 py-2 text-gray-600 dark:text-gray-300">
                <%= p.departamento || '-' %>
              </td>

              <td class="px-3 py-2">
                <% if (Number(p.activo)===1) { %>
                  <span
                    class="rounded bg-green-100 px-2 py-1 text-xs font-semibold text-green-700 dark:bg-green-900 dark:text-green-200">
                    Activo
                  </span>
                  <% } else { %>
                    <span
                      class="rounded bg-gray-100 px-2 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-700 dark:text-gray-200">
                      Inactivo
                    </span>
                    <% } %>
              </td>

              <td class="px-3 py-2">
                <% if (currentUser?.canManagePersonal || currentUser?.idPersonal===p.id) { %>
                  <a href="/usuarios/personal/<%= p.id %>/editar"
                    class="inline-flex items-center gap-1 text-sm font-semibold text-[#033F73] hover:underline dark:text-blue-400">
                    <i class="fa-solid fa-pen-to-square"></i>
                    Editar
                  </a>
                  <% } else { %>
                    <span class="text-sm text-gray-400">Solo lectura</span>
                    <% } %>
              </td>
            </tr>
            <% }) %>
              <% } %>
      </tbody>
    </table>
  </div>
</div>