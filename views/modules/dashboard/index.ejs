<div class="min-w-0 space-y-5">
  <script id="dashboard-data" type="application/json">
    <%- JSON.stringify({
      categorias: categorias || [],
      bombasCriticas: bombasCriticas || [],
      potencialPorArea: potencialPorArea || { labels: [], values: [], colors: [] }
    }) %>
  </script>

  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Dashboard</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Resumen operativo de pozos, servicios y muestreo.
    </p>
  </div>

  <!-- Estadísticas compactas -->
  <div
    class="w-full overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <dl
      class="grid grid-cols-2 divide-x-0 divide-y divide-gray-200 text-gray-900 dark:divide-gray-700 dark:text-white sm:grid-cols-3 sm:divide-x xl:grid-cols-5 xl:divide-y-0">
      <div class="flex min-w-0 flex-col p-4 sm:p-5">
        <dt class="mb-1 text-2xl font-semibold tracking-tight">
          <%= kpis?.total_pozos || 0 %>
        </dt>
        <dd class="text-sm text-gray-500 dark:text-gray-400">Total pozos</dd>
      </div>

      <div class="flex min-w-0 flex-col p-4 sm:p-5">
        <dt class="mb-1 text-2xl font-semibold tracking-tight">
          <%= kpis?.total_cat_1 || 0 %>
        </dt>
        <dd class="text-sm text-gray-500 dark:text-gray-400">Categoría 1</dd>
      </div>

      <div class="flex min-w-0 flex-col p-4 sm:p-5">
        <dt class="mb-1 text-2xl font-semibold tracking-tight">
          <%= kpis?.total_cat_2 || 0 %>
        </dt>
        <dd class="text-sm text-gray-500 dark:text-gray-400">Categoría 2</dd>
      </div>

      <div class="flex min-w-0 flex-col p-4 sm:p-5">
        <dt class="mb-1 text-2xl font-semibold tracking-tight">
          <%= kpis?.total_cat_3 || 0 %>
        </dt>
        <dd class="text-sm text-gray-500 dark:text-gray-400">Categoría 3</dd>
      </div>

      <div class="flex min-w-0 flex-col p-4 sm:p-5">
        <dt class="mb-1 text-2xl font-semibold tracking-tight">
          <%= kpis?.total_en_servicio || 0 %>
        </dt>
        <dd class="text-sm text-gray-500 dark:text-gray-400">En servicio</dd>
      </div>
    </dl>
  </div>

  <div class="grid min-w-0 grid-cols-1 gap-4 xl:grid-cols-3">
    <section
      class="min-w-0 rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Distribución por categoría</h2>
      <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Porcentaje de pozos por categoría.</p>

      <div id="pie-chart" class="min-h-[320px] w-full"></div>
      <div id="pie-legend" class="mt-4 grid grid-cols-1 gap-2"></div>
    </section>


    <section
      class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800 xl:col-span-2">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            Potencial por área
          </h2>
          <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">
            Sumatoria del potencial de pozos categoría 1 en estado activo.
          </p>
        </div>

        <span
          class="inline-flex w-fit items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-[#033F73] dark:bg-gray-700 dark:text-blue-300">
          Barriles
        </span>
      </div>

      <div id="chart-potencial-area" class="min-h-[320px] w-full"></div>
    </section>



    <section
      class="min-w-0 rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800 xl:col-span-2">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Servicios</h2>
      <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Servicios asignados y disponibles.</p>

      <div class="grid min-w-0 grid-cols-2 gap-2 md:grid-cols-4">
        <% if (servicios && servicios.length) { %>
          <% servicios.forEach((item)=> { %>
            <div
              class="min-w-0 rounded-lg border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-700/60">
              <p class="truncate text-xs font-medium uppercase text-gray-500 dark:text-gray-300">
                <%= item.servicio %>
              </p>

              <p class="mt-1 truncate text-lg font-bold text-gray-900 dark:text-white">
                <%= item.pozo_codigo || 'Libre' %>
              </p>

              <p
                class="text-xs <%= item.pozo_codigo ? 'text-green-600 dark:text-green-300' : 'text-gray-500 dark:text-gray-400' %>">
                <%= item.pozo_codigo ? 'Asignado' : (item.subtipo || item.tipo_servicio || 'Disponible' ) %>
              </p>
            </div>
            <% }) %>
              <% } else { %>
                <p class="text-sm text-gray-500 dark:text-gray-400">No hay servicios registrados.</p>
                <% } %>
      </div>
    </section>
  </div>

  <section
    class="dashboard-table-card min-w-0 rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">

    <div class="border-b border-gray-200 dark:border-gray-700">
      <ul class="grid grid-cols-2 text-center text-sm font-medium text-gray-500 dark:text-gray-400"
        id="dashboard-table-tabs" data-tabs-toggle="#dashboard-table-tabs-content" role="tablist">

        <li role="presentation">
          <button
            class="inline-flex w-full items-center justify-center gap-2 border-b-2 border-[#033F73] px-4 py-3 text-[#033F73] dark:border-blue-400 dark:text-blue-400"
            id="muestreo-tab" data-tabs-target="#muestreo-panel" type="button" role="tab" aria-controls="muestreo-panel"
            aria-selected="true">
            <i class="fa-solid fa-vials"></i>
            Muestreo
            <span
              class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-700 dark:bg-red-900 dark:text-red-200">
              <%= kpis?.total_muestras_vencidas || 0 %>
            </span>
          </button>
        </li>

        <li role="presentation">
          <button
            class="inline-flex w-full items-center justify-center gap-2 border-b-2 border-transparent px-4 py-3 hover:border-gray-300 hover:text-gray-700 dark:hover:text-gray-300"
            id="bombas-tab" data-tabs-target="#bombas-panel" type="button" role="tab" aria-controls="bombas-panel"
            aria-selected="false">
            <i class="fa-solid fa-screwdriver-wrench"></i>
            Bombas TVU crítico
            <span
              class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-700 dark:bg-red-900 dark:text-red-200">
              <%= bombasCriticas?.length || 0 %>
            </span>
          </button>
        </li>
      </ul>
    </div>

    <div id="dashboard-table-tabs-content">
      <div id="muestreo-panel" role="tabpanel" aria-labelledby="muestreo-tab" class="p-4">

        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Muestreo</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">
              Pozos activos con muestra vencida o próxima a realizarse.
            </p>
          </div>

          <button type="button" data-export-flowbite-table="tabla-muestreo"
            class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600">
            Exportar Excel
          </button>
        </div>

        <div class="mb-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="rounded-lg bg-red-50 p-3 dark:bg-red-900/20">
            <p class="text-sm text-red-700 dark:text-red-300">Muestras vencidas</p>
            <p class="text-2xl font-bold text-red-800 dark:text-red-200">
              <%= kpis?.total_muestras_vencidas || 0 %>
            </p>
          </div>

          <div class="rounded-lg bg-yellow-50 p-3 dark:bg-yellow-900/20">
            <p class="text-sm text-yellow-700 dark:text-yellow-300">Próximas</p>
            <p class="text-2xl font-bold text-yellow-800 dark:text-yellow-200">
              <%= kpis?.total_proximas_muestras || 0 %>
            </p>
          </div>
        </div>

        <div class="min-w-0 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="w-full overflow-x-auto">
            <table id="tabla-muestreo" class="w-full text-left text-sm">
              <thead class="bg-gray-50 text-xs uppercase text-gray-500 dark:bg-gray-700 dark:text-gray-300">
                <tr>
                  <th class="px-3 py-2">Pozo</th>
                  <th class="px-3 py-2">Última muestra</th>
                  <th class="px-3 py-2">Próx. muestra</th>
                  <th class="px-3 py-2">Estado</th>
                </tr>
              </thead>

              <tbody>
                <% if (muestrasAlerta && muestrasAlerta.length) { %>
                  <% muestrasAlerta.forEach((m)=> { %>
                    <tr class="cursor-pointer border-t hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
                      <td class="whitespace-nowrap px-3 py-2 font-medium text-gray-900 dark:text-white">
                        <%= m.codigo %>
                      </td>

                      <td class="px-3 py-2 text-gray-600 dark:text-gray-300">
                        <%= m.ultima_muestra ? new Date(m.ultima_muestra).toLocaleDateString('es-VE') : '-' %>
                      </td>

                      <td class="px-3 py-2 text-gray-600 dark:text-gray-300">
                        <%= m.prox_muestra ? new Date(m.prox_muestra).toLocaleDateString('es-VE') : '-' %>
                      </td>

                      <td class="px-3 py-2">
                        <% if (m.muestra_vencida) { %>
                          <span
                            class="rounded bg-red-100 px-2 py-1 text-xs font-medium text-red-700 dark:bg-red-900 dark:text-red-200">
                            Vencida
                          </span>
                          <% } else { %>
                            <span
                              class="rounded bg-yellow-100 px-2 py-1 text-xs font-medium text-yellow-700 dark:bg-yellow-900 dark:text-yellow-200">
                              Próxima
                            </span>
                            <% } %>
                      </td>
                    </tr>
                    <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="4" class="px-3 py-4 text-center text-gray-500">
                            No hay alertas de muestreo.
                          </td>
                        </tr>
                        <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="bombas-panel" role="tabpanel" aria-labelledby="bombas-tab" class="hidden p-4">
        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Bombas con alerta TVU</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">
              Crítico desde 365 días. Próximo desde 250 días.
            </p>
          </div>

          <button type="button" data-export-flowbite-table="tabla-bombas-criticas"
            class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600">
            Exportar Excel
          </button>
        </div>

        <div class="min-w-0 overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="w-full overflow-x-auto">
            <table id="tabla-bombas-criticas" class="w-full text-left text-sm">
              <thead class="bg-gray-50 text-xs uppercase text-gray-500 dark:bg-gray-700 dark:text-gray-300">
                <tr>
                  <th class="px-3 py-2">Pozo</th>
                  <th class="px-3 py-2">Método</th>
                  <th class="px-3 py-2">Bomba</th>
                  <th class="px-3 py-2">TVU</th>
                  <th class="px-3 py-2">Estado</th>
                  <th class="px-3 py-2">Días para crítico</th>
                </tr>
              </thead>

              <tbody>
                <% if (bombasCriticas && bombasCriticas.length) { %>
                  <% bombasCriticas.forEach((b)=> {
                    const tvuValue = Number(b.tvu_dias ?? b.tvu ?? 0);
                    const estadoTvu = String(b.estado_tvu || '').toUpperCase();

                    const isCritico = estadoTvu === 'CRITICO' || tvuValue >= 365;
                    const isPendiente = !isCritico && (estadoTvu === 'PENDIENTE' || tvuValue >= 250);
                    const badgeClass = isCritico
                    ? 'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-200'
                    : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';

                    const rowClass = isCritico
                    ? 'bg-red-50/60 hover:bg-red-100 dark:bg-red-950/20 dark:hover:bg-red-900/30'
                    : 'bg-yellow-50/60 hover:bg-yellow-100 dark:bg-yellow-950/20 dark:hover:bg-yellow-900/30';

                    const pozo = b.pozo || b.codigo || '-';
                    const tvu = b.tvu_dias ?? b.tvu ?? '-';
                    const diasParaCritico = b.dias_para_critico ?? '-';
                    const bomba = [b.marca, b.modelo, b.serial].filter(Boolean).join(' ') || '-';
                    %>
                    <tr class="border-t <%= rowClass %> dark:border-gray-700">
                      <td class="whitespace-nowrap px-3 py-2 font-semibold text-gray-900 dark:text-white">
                        <%= pozo %>
                      </td>

                      <td class="px-3 py-2 text-gray-700 dark:text-gray-300">
                        <%= b.metodo || '-' %>
                      </td>

                      <td class="px-3 py-2 text-gray-700 dark:text-gray-300">
                        <%= bomba %>
                      </td>

                      <td class="px-3 py-2">
                        <span class="rounded px-2 py-1 text-xs font-semibold <%= badgeClass %>">
                          <%= tvu %> días
                        </span>
                      </td>

                      <td class="px-3 py-2">
                        <span class="rounded px-2 py-1 text-xs font-semibold <%= badgeClass %>">
                          <%= isCritico ? 'Crítico' : 'Próximo' %>
                        </span>
                      </td>

                      <td class="px-3 py-2 text-gray-700 dark:text-gray-300">
                        <%= isCritico ? '0' : diasParaCritico %>
                      </td>
                    </tr>
                    <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="6" class="px-3 py-4 text-center text-gray-500">
                            No hay bombas críticas o próximas a crítico.
                          </td>
                        </tr>
                        <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="min-w-0 rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Accesos rápidos</h2>
    <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Módulos principales de la alpha.</p>

    <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <a href="/pozos"
        class="rounded-lg border border-gray-200 p-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
        <p class="font-semibold text-gray-900 dark:text-white">Pozos</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">Listado y fichas técnicas.</p>
      </a>

      <a href="/muestras"
        class="rounded-lg border border-gray-200 p-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
        <p class="font-semibold text-gray-900 dark:text-white">Muestras</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">AYS y programación.</p>
      </a>

      <a href="/servicios"
        class="rounded-lg border border-gray-200 p-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
        <p class="font-semibold text-gray-900 dark:text-white">Servicios</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">Asignaciones y cestas.</p>
      </a>

      <a href="/parametros"
        class="rounded-lg border border-gray-200 p-4 hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-700">
        <p class="font-semibold text-gray-900 dark:text-white">Parámetros</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">Datos operacionales.</p>
      </a>
    </div>
  </section>
</div>